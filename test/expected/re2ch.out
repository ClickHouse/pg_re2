(1 row)

SELECT re2replaceregexpone('1,,', '^[,]*|[,]*$', '');
 re2replaceregexpone 
---------------------
 1,,
(1 row)

SELECT re2replaceregexpone(',,1', '^[,]*|[,]*$', '');
 re2replaceregexpone 
---------------------
 1
(1 row)

